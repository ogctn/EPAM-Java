<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.FileAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{16} [%M{10}] - %msg%n</pattern>
        </encoder>
        <file>tests.log</file>
    </appender>

    <root level="error">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>